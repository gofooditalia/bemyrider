<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/_4sdp">

    <!-- Receiver Layout (Left side - Altro utente) -->
    <RelativeLayout
        android:id="@+id/l_receiver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingEnd="@dimen/_40sdp"
        android:visibility="gone">

        <com.app.bemyrider.utils.CircleImageView
            android:id="@+id/img_receiver"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="@dimen/_4sdp" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/layout_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/img_receiver"
            android:layout_marginStart="@dimen/_6sdp"
            android:background="@drawable/bg_msg_left"
            android:orientation="vertical"
            android:padding="@dimen/_10sdp">

            <TextView
                android:id="@+id/txt_receiver_name"
                style="@style/font_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/purple"
                android:textSize="@dimen/_10ssp" />

            <TextView
                android:id="@+id/txt_receiver_msg"
                style="@style/font_regular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_2sdp"
                android:textColor="@color/text"
                android:textSize="@dimen/_11ssp" />

            <TextView
                android:id="@+id/txtUserAttachment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/font_medium"
                android:drawableStart="@drawable/ic_attach"
                android:drawablePadding="@dimen/_4sdp"
                android:text="@string/view_attachment"
                android:layout_marginTop="@dimen/_4sdp"
                android:visibility="gone"
                android:textColor="@color/button"
                android:textSize="@dimen/_10ssp" />

        </androidx.appcompat.widget.LinearLayoutCompat>

        <TextView
            android:id="@+id/txt_datetime_receiver"
            style="@style/font_light"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/layout_right"
            android:layout_toEndOf="@+id/img_receiver"
            android:layout_marginStart="@dimen/_6sdp"
            android:layout_marginTop="@dimen/_2sdp"
            android:textColor="@color/text_light"
            android:textSize="@dimen/_8ssp" />

    </RelativeLayout>

    <!-- Sender Layout (Right side - Tu) -->
    <RelativeLayout
        android:id="@+id/l_sender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/_40sdp"
        android:visibility="gone">

        <com.app.bemyrider.utils.CircleImageView
            android:id="@+id/img_sender"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="@dimen/_4sdp" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/layout_left1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/img_sender"
            android:layout_marginEnd="@dimen/_6sdp"
            android:background="@drawable/bg_msg_right"
            android:orientation="vertical"
            android:padding="@dimen/_10sdp">

            <TextView
                android:id="@+id/txt_sender_name"
                style="@style/font_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:textColor="@color/purple"
                android:textSize="@dimen/_10ssp" />

            <TextView
                android:id="@+id/txt_sender_msg"
                style="@style/font_regular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_2sdp"
                android:textColor="@color/text"
                android:textSize="@dimen/_11ssp" />

            <TextView
                android:id="@+id/txtAttachment"
                style="@style/font_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:drawableStart="@drawable/ic_attach"
                android:drawablePadding="@dimen/_4sdp"
                android:text="@string/view_attachment"
                android:layout_marginTop="@dimen/_4sdp"
                android:textColor="@color/button"
                android:textSize="@dimen/_10ssp"
                android:visibility="gone" />

        </androidx.appcompat.widget.LinearLayoutCompat>

        <TextView
            android:id="@+id/txt_datetime_sender"
            style="@style/font_light"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/layout_left1"
            android:layout_toStartOf="@+id/img_sender"
            android:layout_marginEnd="@dimen/_6sdp"
            android:layout_marginTop="@dimen/_2sdp"
            android:textColor="@color/text_light"
            android:textSize="@dimen/_8ssp" />

    </RelativeLayout>

</LinearLayout>
